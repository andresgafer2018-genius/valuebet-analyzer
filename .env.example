# ── Variables de entorno — copiar a .env y completar ──────────────────────────

# URL del frontend en Vercel (para CORS)
# Ejemplo: https://valuebet-analyzer.vercel.app
FRONTEND_URL=https://TU-APP.vercel.app

# Bankroll inicial en USD
INITIAL_BANKROLL=1000

# ── APIs deportivas (opcionales — el sistema funciona sin ellas en modo demo) ──

# The Odds API — gratis: 500 req/mes
# Registrarse en: https://the-odds-api.com
ODDS_API_KEY=

# API-Football via RapidAPI — gratis: 100 req/día
# Registrarse en: https://rapidapi.com/api-sports/api/api-football
RAPIDAPI_KEY=

# OpenWeatherMap — gratis: 1000 req/día
# Registrarse en: https://openweathermap.org/api
WEATHER_API_KEY=
